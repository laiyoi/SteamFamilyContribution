<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SteamContribution.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://SteamContribution/Styles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <FontFamily x:Key="DefaultFont">Microsoft YaHei,SimSun,Segoe UI,Arial</FontFamily>
    </Application.Resources>
</Application>
